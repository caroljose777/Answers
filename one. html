<!DOCTYPE html>
<html>
<head>
    <title>Frame Layout</title>
</head>

<!-- Divide the page into 2 equal rows (50% each) -->
<frameset rows="50%, 50%">
    
    <!-- First Row: Divide into 2 equal columns (50% each) -->
    <frameset cols="50%, 50%">
        <frame src="red.html">
        <frame src="blue.html">
    </frameset>

    <!-- Second Row: Divide into 2 equal columns (50% each) -->
    <frameset cols="50%, 50%">
        <frame src="green.html">
        <frame src="yellow.html">
    </frameset>

</frameset>
</html>


